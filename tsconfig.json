{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",

    "allowJs": true,
    "checkJs": true,
    "noEmit": true,

    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": false,
    "forceConsistentCasingInFileNames": true,

    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "types": ["@cloudflare/vitest-pool-workers"]
  },
  "include": [
    "functions/**/*.js",
    "functions/**/*.ts",
    "src/js/**/*.js",
    "src/js/**/*.ts",
    "scripts/**/*.js",
    "scripts/**/*.ts",
    "tests/**/*.js",
    "tests/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    ".wrangler",
    ".scripts",
    "public",
    "legacy_snapshots",
    "**/*.min.js"
  ]
}
