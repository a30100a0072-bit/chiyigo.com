{
  "name": "chiyigo-com",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:partials": "node scripts/build-partials.js",
    "build:css": "tailwindcss -c tailwind.config.cjs -i src/css/tailwind.css -o public/css/tailwind.css --minify",
    "build": "npm run build:partials && npm run build:css && npm run lint:handlers && npm run lint:archive-no-delete && npm run lint:migrations",
    "build:watch": "node scripts/build-partials.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:int": "vitest run --config vitest.workers.config.js",
    "test:all": "npm test && npm run test:int",
    "test:security:auth": "vitest run --config vitest.workers.config.js --testNamePattern=\"\\[J-\"",
    "lint": "eslint functions tests && npm run lint:compat-date && npm run lint:workflows",
    "lint:handlers": "node scripts/lint-handlers.js",
    "lint:archive-no-delete": "node scripts/lint-archive-no-delete.js",
    "lint:migrations": "node scripts/lint-migrations-coverage.mjs",
    "lint:compat-date": "node scripts/lint-compat-date.js",
    "lint:workflows": "node scripts/lint-workflows.mjs",
    "typecheck": "tsc -b tsconfig.solution.json",
    "typecheck:ratchet": "node scripts/typecheck-ratchet.mjs",
    "typecheck:ratchet:report": "node scripts/typecheck-ratchet.mjs --report",
    "typecheck:baseline:update": "node scripts/typecheck-ratchet.mjs --update",
    "build:functions": "wrangler pages functions build functions --outdir .tmp-pages-functions-build",
    "strict:tests:preflight": "node scripts/strict-tests-preflight.mjs",
    "verify:browser-pipeline": "node scripts/verify-browser-pipeline.mjs"
  },
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@simplewebauthn/server": "^13.3.0",
    "jose": "^5.9.6",
    "otpauth": "^9.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.40",
    "@types/node": "^20",
    "@vitest/coverage-v8": "^2.1.9",
    "chokidar": "^5.0.0",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "handlebars": "^4.7.9",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^2.1.9",
    "wrangler": "^4.87.0"
  }
}
