{
  "name": "chiyigo-com",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:partials": "node scripts/build-partials.js",
    "build:css": "tailwindcss -c tailwind.config.cjs -i src/css/tailwind.css -o public/css/tailwind.css --minify",
    "build": "npm run build:partials && npm run build:css",
    "build:watch": "node scripts/build-partials.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:int": "vitest run --config vitest.workers.config.js",
    "test:all": "npm test && npm run test:int",
    "lint": "eslint functions tests"
  },
  "dependencies": {
    "jose": "^5.9.6",
    "otpauth": "^9.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.40",
    "@vitest/coverage-v8": "^2.1.9",
    "chokidar": "^5.0.0",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "handlebars": "^4.7.9",
    "tailwindcss": "^3.4.17",
    "vitest": "^2.1.9"
  }
}
