<div class="m-topbar" id="m-topbar">
  <div class="m-tb-inner">
    <a href="{{brandHref}}" class="m-tb-brand">
      <img src="{{pathPrefix}}images/logo-light.png" alt="CHIYIGO" class="m-logo-img logo-light">
      <img src="{{pathPrefix}}images/logo-dark.png"  alt="CHIYIGO" class="m-logo-img logo-dark">
    </a>
    <div class="m-tb-right">
      <a href="{{loginHref}}" class="m-login-btn" data-auth="guest" aria-label="{{loginLabel}}">
        <svg viewBox="0 0 16 16" fill="none"><circle cx="8" cy="5.5" r="2.5" stroke="currentColor" stroke-width="1.3" fill="none"/><path d="M2 13.5c0-2.5 2.5-4.5 6-4.5s6 2 6 4.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" fill="none"/></svg>
      </a>
      <a href="/dashboard.html" class="m-login-btn" data-auth="member" hidden aria-label="會員中心">
        <svg viewBox="0 0 16 16" fill="none"><circle cx="8" cy="5.5" r="2.5" stroke="currentColor" stroke-width="1.3" fill="none"/><path d="M2 13.5c0-2.5 2.5-4.5 6-4.5s6 2 6 4.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" fill="none"/></svg>
      </a>
      <button class="m-theme-btn" id="m-theme-btn" aria-label="切換主題">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="icon-theme"><path d="M12 8a2.83 2.83 0 0 1 4 4 4 4 0 0 1-4-4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.9 4.9 1.4 1.4"/><path d="m17.7 17.7 1.4 1.4"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.3 17.7-1.4 1.4"/><path d="m19.1 4.9-1.4 1.4"/></svg>
      </button>
      <button class="m-theme-btn" id="m-lang-btn" aria-label="切換語言">
        <svg viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3"/><path d="M8 2c-1.2 1.5-2 3.6-2 6s.8 4.5 2 6M8 2c1.2 1.5 2 3.6 2 6s-.8 4.5-2 6M2 8h12M2.8 5.5h10.4M2.8 10.5h10.4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
      </button>
      <button class="m-ham-btn" id="m-ham-btn" aria-label="開啟選單" aria-expanded="false" aria-controls="m-overlay">
        <span class="m-ham-line"></span>
        <span class="m-ham-line"></span>
      </button>
    </div>
  </div>
  <div class="m-top-lang-drop" id="m-top-lang-drop">
    <button class="lang-opt active" data-lang="zh-TW">繁體中文</button>
    <button class="lang-opt" data-lang="en">English</button>
    <button class="lang-opt" data-lang="ja">日本語</button>
    <button class="lang-opt" data-lang="ko">한국어</button>
  </div>
</div>
