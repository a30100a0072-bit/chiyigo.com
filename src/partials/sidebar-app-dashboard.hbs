<aside class="dash-sidebar">
  <a href="/" class="sb-brand" aria-label="CHIYIGO">
    <img src="/images/logo-light.png" alt="CHIYIGO" class="sb-logo-img logo-light">
    <img src="/images/logo-dark.png"  alt="CHIYIGO" class="sb-logo-img logo-dark">
  </a>

  <nav class="sb-nav" aria-label="會員功能">
    <a href="/" class="sb-item">
      <svg class="sb-icon" viewBox="0 0 16 16" fill="none"><path d="M2 9L8 3l6 6v6H10v-4H6v4H2z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" fill="none"/></svg>
      <span class="sb-label" data-i18n="nav_home">首頁</span>
    </a>

    <div class="sb-group-label" data-i18n="grp_account">帳號</div>
    <button type="button" class="sb-item active" data-scroll="user-card">
      <svg class="sb-icon" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="5.5" r="2.5" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M2 14.5a6 6 0 0 1 12 0" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" fill="none"/></svg>
      <span class="sb-label" data-i18n="nav_overview">帳號總覽</span>
    </button>
    <button type="button" class="sb-item" data-scroll="bind-section">
      <svg class="sb-icon" viewBox="0 0 16 16" fill="none"><path d="M6.5 9.5L4 12a2 2 0 11-2.83-2.83L3.5 6.83M9.5 6.5L12 4a2 2 0 112.83 2.83L12.5 9.17M5.5 10.5l5-5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" fill="none"/></svg>
      <span class="sb-label" data-i18n="nav_bind">帳號綁定</span>
    </button>
    <button type="button" class="sb-item" data-scroll="req-section">
      <svg class="sb-icon" viewBox="0 0 16 16" fill="none"><rect x="3" y="2" width="10" height="12" rx="1.4" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M5.5 5.5h5M5.5 8h5M5.5 10.5h3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
      <span class="sb-label" data-i18n="nav_req">我的需求單</span>
    </button>

    <div class="sb-group-label" data-i18n="grp_security">安全</div>
    <button type="button" class="sb-item" data-scroll="tfa-section">
      <svg class="sb-icon" viewBox="0 0 16 16" fill="none"><path d="M8 1.5L3 3.5v4c0 3 2 5.6 5 7 3-1.4 5-4 5-7v-4z" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linejoin="round"/><path d="M6 8l1.5 1.5L10 7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
      <span class="sb-label" data-i18n="nav_2fa">雙重驗證</span>
    </button>
    <button type="button" class="sb-item" id="sb-nav-setpw" data-scroll="setpw-section" hidden>
      <svg class="sb-icon" viewBox="0 0 16 16" fill="none"><rect x="3" y="7" width="10" height="7" rx="1.3" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M5.5 7V4.5a2.5 2.5 0 015 0V7" stroke="currentColor" stroke-width="1.4" fill="none"/></svg>
      <span class="sb-label" data-i18n="nav_setpw">設定密碼</span>
    </button>
    <button type="button" class="sb-item" id="sb-nav-changepw" data-scroll="changepw-section">
      <svg class="sb-icon" viewBox="0 0 16 16" fill="none"><rect x="3" y="7" width="10" height="7" rx="1.3" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M5.5 7V4.5a2.5 2.5 0 015 0V7" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M8 9.5v2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
      <span class="sb-label" data-i18n="nav_changepw">修改密碼</span>
    </button>
    <button type="button" class="sb-item" data-scroll="devices-section">
      <svg class="sb-icon" viewBox="0 0 16 16" fill="none"><rect x="2" y="3" width="9" height="7" rx="1.2" stroke="currentColor" stroke-width="1.4" fill="none"/><rect x="10" y="6" width="4" height="8" rx="0.8" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M5.5 12h2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
      <span class="sb-label" data-i18n="nav_devices">我的裝置</span>
    </button>
    <button type="button" class="sb-item" data-scroll="passkeys-section">
      <svg class="sb-icon" viewBox="0 0 16 16" fill="none"><circle cx="6" cy="8" r="3" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M9 8h5M12 8v2.5M14 8v1.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
      <span class="sb-label" data-i18n="nav_passkeys">Passkey</span>
    </button>

    <div class="sb-group-label" data-i18n="grp_payments">金流</div>
    <button type="button" class="sb-item" data-scroll="wallets-section">
      <svg class="sb-icon" viewBox="0 0 16 16" fill="none"><rect x="2" y="4" width="12" height="9" rx="1.4" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M2 6h12" stroke="currentColor" stroke-width="1.4"/><circle cx="11" cy="9.5" r="0.9" fill="currentColor"/></svg>
      <span class="sb-label" data-i18n="nav_wallets">錢包</span>
    </button>
    <button type="button" class="sb-item" data-scroll="payments-section">
      <svg class="sb-icon" viewBox="0 0 16 16" fill="none"><path d="M2 5h12v7a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V5z" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M2 5l1.5-2h9L14 5" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" fill="none"/><path d="M5 9h2M9 9h2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
      <span class="sb-label" data-i18n="nav_payments">付款</span>
    </button>
  </nav>

  <div class="sb-bottom">
    <div class="sb-cta">
      <p class="sb-cta-desc" data-i18n="cta_desc">讓我一起打造最適合你的數位解決方案！</p>
      <a href="/requisition.html" class="sb-cta-btn" data-i18n="cta_btn">開始諮詢</a>
    </div>
    <button type="button" class="sb-item danger sb-logout-pad" data-action="logout">
      <svg class="sb-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75"/></svg>
      <span class="sb-label" data-i18n="logout_header">登出</span>
    </button>
    <div class="sb-footer">
      <div class="lang-dropdown" id="db-lang-drop">
        <button class="db-lang-opt lang-opt active" data-lang="zh-TW">繁體中文</button>
        <button class="db-lang-opt lang-opt" data-lang="en">English</button>
        <button class="db-lang-opt lang-opt" data-lang="ja">日本語</button>
        <button class="db-lang-opt lang-opt" data-lang="ko">한국어</button>
      </div>
      <div class="sb-foot-icons">
        <button class="sb-foot-btn" id="db-theme-btn" type="button" aria-label="切換明暗">
          <svg viewBox="0 0 24 24" fill="none" class="icon-theme" aria-hidden="true"><circle cx="7" cy="7" r="2.5" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M7 1V3M7 11V13M1 7H3M11 7H13M2.76 2.76 4.17 4.17M9.83 9.83 11.24 11.24M2.76 11.24 4.17 9.83M9.83 4.17 11.24 2.76" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M23 17a6 6 0 1 1-6-6 4.5 4.5 0 1 0 6 6z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
        </button>
        <button class="sb-foot-btn" id="db-globe-btn" type="button" aria-label="切換語言">
          <svg viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3"/><path d="M8 2c-1.2 1.5-2 3.6-2 6s.8 4.5 2 6M8 2c1.2 1.5 2 3.6 2 6s-.8 4.5-2 6M2 8h12M2.8 5.5h10.4M2.8 10.5h10.4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
        </button>
      </div>
      <span class="sb-copyright">© 2026 chiyigo</span>
    </div>
