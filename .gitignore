# 註：public/*.html 是 npm run build 的產物（來源：src/pages + src/partials），
# 但因 Cloudflare Pages 新版 dashboard UI 無法設 build command，故仍 commit 進 repo。
# 修改流程：改 src/ → npm run build → commit src/ 與 public/ 一起推。
# （階段 7 會加 pre-commit hook 自動 build。）
.scripts/

# audit 中介產物（用 scripts/audit-error-i18n.mjs 重跑即可）
scripts/audit-error-i18n.out.json
.audit-watch-*

# TypeScript 增量編譯快取（typecheck 是 noEmit 通常不會產，保險用）
*.tsbuildinfo
.tmp-pages-functions-build/
