node_modules/
.wrangler/
.dev.vars
dist/
*.local
.claude/

# 註：public/*.html 是 npm run build 的產物（來源：src/pages + src/partials），
# 但因 Cloudflare Pages 新版 dashboard UI 無法設 build command，故仍 commit 進 repo。
# 修改流程：改 src/ → npm run build → commit src/ 與 public/ 一起推。
# （階段 7 會加 pre-commit hook 自動 build。）
.scripts/

# audit 中介產物（用 scripts/audit-error-i18n.mjs 重跑即可）
scripts/audit-error-i18n.out.json
.audit-watch-*

# TypeScript 增量編譯快取（typecheck 是 noEmit 通常不會產，保險用）
*.tsbuildinfo
.tmp-pages-functions-build/

# Stage 4.5a browser pipeline canary emit 暫存（scripts/verify-browser-pipeline.mjs 跑完即清）
.tmp-pipeline-canary/

# PR 0.2c-pre-1b spike credentials（spike-r2-lock.mjs session env source）
# 永不 commit；ad-hoc 命名都涵蓋以防 typo（secret/secert/secrets/.env*/.*.secrets）
secret
secert
secrets
.env
.env.local
*.secrets
# spike 跑完輸出（含 R2 endpoint + response data；可以提交但 fixture 走另一路徑）
spike-setup.json
spike-test.json

# 本機 ad-hoc secret container（user 暫存 secret 給 Claude 整理；handled via global
# CLAUDE.md §安全要求 Secret container 紀律）。檔案存在期間禁直接 grep / cat。
# 留 pattern 給未來臨時 secret 處理使用，user 自行決定何時 rm。
.canary-secret-tmp
.canary-*.tmp
