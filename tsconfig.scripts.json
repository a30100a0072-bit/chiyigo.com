{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",

    "lib": ["ES2022"],
    "types": ["node"],

    "allowJs": true,
    "checkJs": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": false,

    "composite": true,
    "noEmit": true,
    "outDir": ".tscache/scripts"
  },
  "include": [
    "scripts/**/*.js",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "scripts/fixtures/**"
  ]
}
